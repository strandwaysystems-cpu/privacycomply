---
import BaseLayout from '@layouts/BaseLayout.astro';

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "PrivacyComply",
  "url": "https://privacycomply.io/",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://privacycomply.io/?s={search_term_string}",
    "query-input": "required name=search_term_string"
  },
  "publisher": {
    "@type": "Organization",
    "name": "PrivacyComply",
    "url": "https://privacycomply.io/"
  }
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "PrivacyComply",
  "url": "https://privacycomply.io/",
  "description": "Independent reviews and guides for cookie consent banners, GDPR compliance software, and data privacy tools for websites and SaaS businesses.",
  "areaServed": "Worldwide"
};
---
<BaseLayout
  title="PrivacyComply — Honest Reviews of Cookie Consent & GDPR Compliance Tools (2026)"
  description="Plain-English reviews of cookie consent banners, GDPR compliance software, and privacy policy generators. Pick the right tool in minutes, not weeks."
  canonical="/"
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </Fragment>

  <section class="hero">
    <div class="hero__inner">
      <span class="hero__eyebrow">Independent reviews · Updated 2026</span>
      <h1>Pick the right privacy compliance tool — in minutes, not weeks.</h1>
      <p class="hero__sub">We review and compare cookie consent banners, GDPR tools, and privacy policy generators so you don't have to. No vendor sponsorships. Just clear answers for website owners, agencies, and SaaS teams.</p>
      <div class="hero__ctas">
        <a href="/best-cookie-consent-tools-2026.html" class="btn btn-primary">See the Best Cookie Tools 2026</a>
        <a href="/what-is-gdpr.html" class="btn btn-ghost">Start with the GDPR Guide</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="section__eyebrow">Featured Reviews</span>
      <h2 class="section__title">Compliance tools we've reviewed in depth</h2>
      <p class="section__intro">Each tool below is rated on price, ease of setup, regulatory coverage (GDPR, CCPA, PIPEDA, LGPD), and whether it actually does what its sales page claims.</p>

      <div class="card-grid">
        <article class="card">
          <span class="card__badge card__badge--top">Editor's Pick · SMB</span>
          <h3 class="card__title">CookieYes</h3>
          <p class="card__desc">The fastest cookie consent banner to set up, with native GDPR, CCPA, and LGPD modes, Google Consent Mode v2 support, and a generous free tier.</p>
          <div class="card__meta">
            <span><strong>From:</strong> Free</span>
            <span><strong>Score:</strong> 4.8/5</span>
          </div>
          <div class="card__cta">
            <a href="/cookieyes-review.html" class="card__link">Read full review →</a>
          </div>
        </article>

        <article class="card">
          <span class="card__badge">Best All-in-One</span>
          <h3 class="card__title">iubenda</h3>
          <p class="card__desc">Privacy policy + cookie banner + consent management in one platform. Strongest choice if you need a customised privacy policy and full compliance stack.</p>
          <div class="card__meta">
            <span><strong>From:</strong> €4.99/mo</span>
            <span><strong>Score:</strong> 4.6/5</span>
          </div>
          <div class="card__cta">
            <a href="/iubenda-review.html" class="card__link">Read full review →</a>
          </div>
        </article>

        <article class="card">
          <span class="card__badge">Best Free Tier</span>
          <h3 class="card__title">Termly</h3>
          <p class="card__desc">Free tier covering cookie banner, privacy policy, terms, and Do Not Sell forms — strong for US-focused small businesses on a tight budget.</p>
          <div class="card__meta">
            <span><strong>From:</strong> Free</span>
            <span><strong>Score:</strong> 4.0/5</span>
          </div>
          <div class="card__cta">
            <a href="/termly-review.html" class="card__link">Read full review →</a>
          </div>
        </article>

        <article class="card">
          <span class="card__badge card__badge--top">Best for Multi-Site</span>
          <h3 class="card__title">Enzuzo</h3>
          <p class="card__desc">Ten domains on one plan, native Shopify and Webflow apps, and a real DSAR workflow from $22/mo — the strongest mid-market pick for agencies and portfolio operators running multiple sites.</p>
          <div class="card__meta">
            <span><strong>From:</strong> $59/mo</span>
            <span><strong>Score:</strong> 4.5/5</span>
          </div>
          <div class="card__cta">
            <a href="/enzuzo-review.html" class="card__link">Read full review →</a>
          </div>
        </article>

        <article class="card">
          <span class="card__badge">Enterprise · Security</span>
          <h3 class="card__title">NordLayer</h3>
          <p class="card__desc">Not a cookie tool — but the missing layer for GDPR compliance: business VPN with ISO 27001, SOC 2, and HIPAA-ready controls for remote teams handling EU data.</p>
          <div class="card__meta">
            <span><strong>From:</strong> $8/user/mo</span>
            <span><strong>Score:</strong> 4.7/5</span>
          </div>
          <div class="card__cta">
            <a href="/nordlayer-review.html" class="card__link">Read full review →</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--paper">
    <div class="container">
      <span class="section__eyebrow">Start Here</span>
      <h2 class="section__title">Plain-English compliance guides</h2>
      <p class="section__intro">Regulations move fast. These guides are reviewed quarterly and updated whenever a regulator issues new guidance.</p>

      <div class="card-grid">
        <article class="card">
          <h3 class="card__title">What is GDPR? A guide for website owners</h3>
          <p class="card__desc">Who it applies to, what it actually requires of your site, and the simplest path to compliance — without the legalese.</p>
          <div class="card__cta"><a href="/what-is-gdpr.html" class="card__link">Read the guide →</a></div>
        </article>

        <article class="card">
          <h3 class="card__title">GDPR vs CCPA: what every site needs to know</h3>
          <p class="card__desc">The four real differences between Europe's GDPR and California's CCPA, plus a decision tree for which one (or both) you need to comply with.</p>
          <div class="card__cta"><a href="/gdpr-vs-ccpa.html" class="card__link">Read the guide →</a></div>
        </article>

        <article class="card">
          <h3 class="card__title">Best cookie consent tools, ranked for 2026</h3>
          <p class="card__desc">CookieYes vs Termly vs iubenda vs Osano — head-to-head comparison with our recommendation for each site type.</p>
          <div class="card__cta"><a href="/best-cookie-consent-tools-2026.html" class="card__link">Read the comparison →</a></div>
        </article>

        <article class="card">
          <h3 class="card__title">iubenda vs Termly vs Osano: Complete Comparison 2026</h3>
          <p class="card__desc">Pricing, cookie consent, GDPR/CCPA coverage, and usability compared side-by-side — find out which tool fits your business.</p>
          <div class="card__cta"><a href="/iubenda-vs-termly-vs-osano.html" class="card__link">Read the comparison →</a></div>
        </article>

        <article class="card">
          <h3 class="card__title">Do I need a cookie banner?</h3>
          <p class="card__desc">A plain-English decision tree covering GDPR, CCPA, and other privacy laws — find out in under two minutes whether your site needs a consent banner.</p>
          <div class="card__cta"><a href="/do-i-need-a-cookie-banner.html" class="card__link">Read the guide →</a></div>
        </article>

        <article class="card">
          <h3 class="card__title">Does GDPR apply to US companies?</h3>
          <p class="card__desc">Yes — and here is exactly what that means. Who is covered, what you must do, and a compliance checklist built for US-based websites and SaaS products.</p>
          <div class="card__cta"><a href="/gdpr-for-us-companies.html" class="card__link">Read the guide →</a></div>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--navy">
    <div class="container">
      <span class="section__eyebrow" style="color:#86efac;">Why PrivacyComply</span>
      <h2 class="section__title">Built for the people who actually have to ship the site</h2>
      <p class="section__intro" style="color:#cbd5e1;">No legal jargon walls. No 12-tab vendor comparisons. Just the answer you came here for, with sources you can verify.</p>
      <div class="card-grid">
        <div class="card" style="background:rgba(255,255,255,0.04); border-color:#1e3a5f;">
          <h3 class="card__title" style="color:white;">Reviewed, not just listed</h3>
          <p class="card__desc" style="color:#cbd5e1;">This site runs on iubenda, so the iubenda coverage is first-hand. For other tools, we evaluate vendor documentation, pricing pages, and verified-user reviews — and we say which is which.</p>
        </div>
        <div class="card" style="background:rgba(255,255,255,0.04); border-color:#1e3a5f;">
          <h3 class="card__title" style="color:white;">Transparent monetisation</h3>
          <p class="card__desc" style="color:#cbd5e1;">We earn commission when you sign up via our links. We tell you which links are affiliate, and we never let commission size dictate ranking.</p>
        </div>
        <div class="card" style="background:rgba(255,255,255,0.04); border-color:#1e3a5f;">
          <h3 class="card__title" style="color:white;">Reviewed quarterly</h3>
          <p class="card__desc" style="color:#cbd5e1;">Regulations change. Pricing changes. We re-check every recommendation at least four times a year and date-stamp every page.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
