.tool-card__body { padding: 1.25rem 1.5rem; }
.pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1rem; }
.pros ul, .cons ul { margin: 0.5rem 0 0; padding-left: 1.1rem; font-size: 0.9rem; }
.pros ul { color: #166534; }
.cons ul { color: #991b1b; }
.tool-card__best-for { font-size: 0.95rem; margin: 0.75rem 0 1rem; padding: 0.6rem 1rem; background: var(--surface-2, #f8fafc); border-radius: 0.4rem; }
.tool-card__cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }
