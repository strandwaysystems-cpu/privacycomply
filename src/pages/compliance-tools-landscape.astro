---
import BaseLayout from '@layouts/BaseLayout.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"https://privacycomply.io/"},
    {"@type":"ListItem","position":2,"name":"Compliance Tools Landscape","item":"https://privacycomply.io/compliance-tools-landscape.html"}
  ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Privacy & Compliance Tools Landscape 2026",
  "description": "Directory of 50+ privacy and compliance tools across 8 categories — cookie banners, policy generators, DSAR platforms, data discovery, breach monitoring, business VPN, security training, and audit automation.",
  "datePublished": "2026-06-27",
  "dateModified": "2026-06-27",
  "author": {"@type":"Organization","name":"PrivacyComply"},
  "publisher": {"@type":"Organization","name":"PrivacyComply","url":"https://privacycomply.io/"},
  "mainEntityOfPage": "https://privacycomply.io/compliance-tools-landscape.html"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"Why is so much pricing on this page marked 'custom quote'?","acceptedAnswer":{"@type":"Answer","text":"Enterprise privacy tools (OneTrust, TrustArc, Securiti.ai, BigID, Vanta, Drata, Secureframe) almost universally hide pricing behind a sales call. We cite third-party procurement sources (Vendr, CheckThat.ai, Spendflo) where independent pricing data exists so you can benchmark before that call."}},
    {"@type":"Question","name":"Do I need tools from every category?","acceptedAnswer":{"@type":"Answer","text":"No. A small business website typically needs a cookie banner and a privacy policy generator. As you grow, you add DSAR tooling, then training, then audit automation. Data discovery and breach monitoring become relevant once you process large volumes of personal data or pursue formal certifications."}},
    {"@type":"Question","name":"Which categories overlap?","acceptedAnswer":{"@type":"Answer","text":"Several tools span multiple categories. iubenda and Termly cover both cookie consent and privacy policy. Securiti.ai and Transcend cover both DSAR and data discovery. Osano combines cookie consent with light DSAR and vendor monitoring. We flag dual-listed tools inline."}},
    {"@type":"Question","name":"Is this list complete?","acceptedAnswer":{"@type":"Answer","text":"It covers the dominant tools we see in each category as of mid-2026. There are smaller and regional players in every category that we have not listed. If a tool you use is missing and you think it deserves coverage, email corrections@privacycomply.io."}},
    {"@type":"Question","name":"How current is this pricing?","acceptedAnswer":{"@type":"Answer","text":"All pricing was verified directly on vendor pricing pages in June 2026. Privacy and compliance pricing changes quickly — OneTrust raised its minimum contract from open self-serve to $10,000 per year in Q2 2026, and Cookiebot doubled base prices in August 2025. We re-verify quarterly. Always confirm with the vendor before signing."}},
    {"@type":"Question","name":"Why are some categories thinner than others?","acceptedAnswer":{"@type":"Answer","text":"Data discovery, breach monitoring, and business VPN are dominated by 3-5 players each at the enterprise level — adding more tools would mean listing point solutions that few buyers actually evaluate. Cookie consent has 10+ credible options because the category is younger, more SMB-accessible, and more crowded."}}
  ]
};
---
<BaseLayout
  title="Privacy & Compliance Tools Landscape 2026: 50+ Tools Across 8 Categories | PrivacyComply"
  description="Directory of 50+ privacy and compliance tools — cookie banners, policy generators, DSAR platforms, data discovery, breach monitoring, business VPN, security training, and audit automation. Pricing, positioning, and category overview for each."
  canonical="/compliance-tools-landscape.html"
  ogType="article"
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="article-hero">
    <div class="container">
      <p class="breadcrumbs"><a href="/">Home</a><span>&#8250;</span> Compliance Tools Landscape</p>
      <h1>Privacy &amp; Compliance Tools Landscape 2026</h1>
      <div class="article-meta">
        <span>Updated June 27, 2026</span>
        <span>50+ tools &middot; 8 categories</span>
        <span>Pricing verified on vendor sites</span>
      </div>
    </div>
  </section>

  <article class="article">

    <div class="tldr">
      <strong>What this page is:</strong> A working directory of the tools that dominate each layer of the privacy and compliance stack in 2026. One line per tool and the current starting price. Use it to scope vendors before a procurement call &mdash; not as a ranked review. For ranked head-to-head reviews, see <a href="/reviews.html">Reviews</a> and <a href="/best-cookie-consent-tools-2026.html">Best Cookie Consent Tools 2026</a>.
    </div>

    <div class="disclosure">
      <strong>Affiliate disclosure:</strong> Where we run an affiliate link with a vendor it is tagged below. Inclusion on this page is not based on commission &mdash; tools without affiliate programs are listed alongside tools that pay us. See our <a href="/about.html#disclosure">full disclosure</a>.
    </div>

    <h2>Jump to a category</h2>
    <ul>
      <li><a href="#cookie-consent">1. Cookie consent banners</a> &mdash; 10 tools</li>
      <li><a href="#privacy-policy">2. Privacy policy generators</a> &mdash; 6 tools</li>
      <li><a href="#dsar-cmp">3. DSAR &amp; consent management platforms</a> &mdash; 6 tools</li>
      <li><a href="#data-discovery">4. Data discovery &amp; mapping</a> &mdash; 4 tools</li>
      <li><a href="#breach-monitoring">5. Breach monitoring &amp; data leak detection</a> &mdash; 4 tools</li>
      <li><a href="#business-vpn">6. Business VPN &amp; secure access</a> &mdash; 4 tools</li>
      <li><a href="#security-training">7. Employee privacy &amp; security training</a> &mdash; 4 tools</li>
      <li><a href="#audit-automation">8. Audit &amp; certification automation</a> &mdash; 4 tools</li>
    </ul>

    <h2>How to read this page</h2>
    <p>Each entry includes a one-line description and the starting price (or a note that pricing is gated, with a third-party procurement source where independent data exists). Pricing was verified on vendor pricing pages in June 2026. Tools with an existing in-depth PrivacyComply review link to it.</p>

    <!-- ================= CATEGORY 1: COOKIE CONSENT ================= -->
    <h2 id="cookie-consent">1. Cookie consent banners</h2>
    <p>Cookie consent management platforms (CMPs) display compliant banners, scan for trackers, record consent choices, and satisfy GDPR, CCPA, and similar laws. The category spans free tiers for personal blogs through six-figure enterprise contracts. For most SMB sites the decision is between three or four self-serve tools; for publishers and large enterprises the shortlist is different.</p>

    <div class="card-grid">

      <article class="card">
        <span class="card__badge card__badge--top">Editor's Pick &middot; SMB</span>
        <h3 class="card__title">CookieYes</h3>
        <p class="card__desc">Self-serve cookie consent banner for SMBs &mdash; easy setup, generous free tier, used by 1.5M+ sites.</p>
        <div class="card__meta"><span><strong>From:</strong> Free / <a href="https://www.cookieyes.com/pricing/" rel="noopener">$10&#47;mo</a></span></div>
        <div class="card__cta"><a href="/cookieyes-review.html" class="card__link">Full review &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">iubenda</h3>
        <p class="card__desc">All-in-one compliance suite (consent + policy + cookie banner + T&amp;C) for agencies and developers across 170+ countries.</p>
        <div class="card__meta"><span><strong>From:</strong> Free / <a href="https://www.iubenda.com/en/pricing" rel="noopener">&euro;4.99&#47;mo</a></span></div>
        <div class="card__cta"><a href="/iubenda-review.html" class="card__link">Full review &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">Termly</h3>
        <p class="card__desc">US-focused privacy policy and cookie consent tool aimed at small businesses; auto-updating policies and Free tier with watermark.</p>
        <div class="card__meta"><span><strong>From:</strong> Free / <a href="https://termly.io/pricing/" rel="noopener">$14&#47;mo</a></span></div>
        <div class="card__cta"><a href="/termly-review.html" class="card__link">Full review &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">Osano</h3>
        <p class="card__desc">Privacy platform for mid-market &mdash; cookie consent plus DSAR, data mapping, and vendor monitoring in one product.</p>
        <div class="card__meta"><span><strong>From:</strong> Free / <a href="https://www.osano.com/plans" rel="noopener">$199&#47;mo</a></span></div>
        <div class="card__cta"><a href="https://www.osano.com" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">Cookiebot (by Usercentrics)</h3>
        <p class="card__desc">Scan-based CMP priced by subpage count per domain; TCF 2.2 certified. <em>Base prices doubled in August 2025 after the Usercentrics acquisition.</em></p>
        <div class="card__meta"><span><strong>From:</strong> Free / <a href="https://www.cookiebot.com/en/pricing/" rel="noopener">&euro;7&#47;mo</a></span></div>
        <div class="card__cta"><a href="https://www.cookiebot.com" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">Usercentrics</h3>
        <p class="card__desc">Enterprise CMP from the parent of Cookiebot; session-based pricing for Web, App, and CTV channels.</p>
        <div class="card__meta"><span><strong>From:</strong> Free / <a href="https://usercentrics.com/pricing/" rel="noopener">&euro;7&#47;mo</a></span></div>
        <div class="card__cta"><a href="https://usercentrics.com" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">OneTrust Cookie Consent</h3>
        <p class="card__desc">Enterprise consent module within the OneTrust platform. <em>Minimum $10,000/year ACV as of Q2 2026 &mdash; impractical as a standalone banner.</em></p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://www.vendr.com/marketplace/onetrust" rel="noopener">~$10K&#47;yr min</a></span></div>
        <div class="card__cta"><a href="https://www.onetrust.com/products/cookie-consent/" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">TrustArc Cookie Consent</h3>
        <p class="card__desc">Enterprise cookie consent and privacy management from a 1997-founded vendor; sales-led, no self-serve pricing.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://checkthat.ai/brands/trustarc/pricing" rel="noopener">~$8&ndash;15K&#47;yr</a></span></div>
        <div class="card__cta"><a href="https://trustarc.com/cookie-consent-manager/" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">Didomi</h3>
        <p class="card__desc">European enterprise CMP with strong media and publisher integrations; IAB TCF and GPP certified.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://www.enzuzo.com/blog/didomi-pricing" rel="noopener">~&euro;250&#47;mo</a></span></div>
        <div class="card__cta"><a href="https://www.didomi.io" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">Secure Privacy</h3>
        <p class="card__desc">GDPR/CCPA cookie consent plus privacy policy generator; SOC 2 certified; aimed at SMBs that want both bundled.</p>
        <div class="card__meta"><span><strong>From:</strong> Free / <a href="https://secureprivacy.ai/pricing" rel="noopener">$15&#47;mo</a></span></div>
        <div class="card__cta"><a href="https://secureprivacy.ai" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <span class="card__badge card__badge--top">Best for Multi-Site</span>
        <h3 class="card__title">Enzuzo</h3>
        <p class="card__desc">Mid-market CMP with the strongest multi-domain pricing on the market &mdash; 10 domains for $59&#47;mo on the Pro plan. Native Shopify and Webflow apps, real DSAR workflow from $22&#47;mo, Google CMP Gold, IAB TCF 2.3. Canadian-built, Quebec Law 25 covered.</p>
        <div class="card__meta"><span><strong>From:</strong> Free / <a href="https://www.enzuzo.com/pricing" rel="noopener">$7&#47;mo</a></span></div>
        <div class="card__cta"><a href="/enzuzo-review.html" class="card__link">Read full review &#8594;</a></div>
      </article>

    </div>

    <!-- ================= CATEGORY 2: PRIVACY POLICY ================= -->
    <h2 id="privacy-policy">2. Privacy policy generators</h2>
    <p>Privacy policy generators produce the legal text that GDPR, CCPA, and similar laws require websites to display. The spectrum runs from free static templates to dynamically updating, attorney-drafted policies that auto-adjust when laws change. Key considerations: does the policy auto-update, is it hosted (so you can link to it), and does it cover multiple regulations.</p>

    <div class="card-grid">

      <article class="card">
        <h3 class="card__title">Termly</h3>
        <p class="card__desc">Auto-updating privacy policies, cookie policies, and terms for small business websites; US-centric but covers GDPR.</p>
        <div class="card__meta"><span><strong>From:</strong> Free / <a href="https://termly.io/pricing/" rel="noopener">$14&#47;mo</a></span></div>
        <div class="card__cta"><a href="/termly-review.html" class="card__link">Full review &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">iubenda</h3>
        <p class="card__desc">Lawyer-drafted, auto-updating privacy policy for websites and apps; covers 170+ jurisdictions with a modular clause library.</p>
        <div class="card__meta"><span><strong>From:</strong> Free / <a href="https://www.iubenda.com/en/pricing" rel="noopener">&euro;4.99&#47;mo</a></span></div>
        <div class="card__cta"><a href="/iubenda-review.html" class="card__link">Full review &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">Termageddon</h3>
        <p class="card__desc">Attorney-authored, auto-updating privacy policies; built for small businesses and the web agencies that serve them.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://termageddon.com/pricing/" rel="noopener">$12&#47;mo</a></span></div>
        <div class="card__cta"><a href="https://termageddon.com" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">FreePrivacyPolicy</h3>
        <p class="card__desc">Free generator for basic privacy policies, terms, and disclaimers; static output, no subscription required.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://www.freeprivacypolicy.com/" rel="noopener">Free</a></span></div>
        <div class="card__cta"><a href="https://www.freeprivacypolicy.com/" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">PrivacyPolicies.com</h3>
        <p class="card__desc">Free hosted privacy policy, T&amp;C, EULA, and refund policy generator with optional one-time premium clause add-ons.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://www.privacypolicies.com/pricing/" rel="noopener">Free + paid clauses</a></span></div>
        <div class="card__cta"><a href="https://www.privacypolicies.com" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">GetTerms.io</h3>
        <p class="card__desc">Subscription privacy policy and terms generator with strong agency reseller pricing (40&ndash;70% bulk discounts).</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://getterms.io/pricing" rel="noopener">$5&#47;mo</a></span></div>
        <div class="card__cta"><a href="https://getterms.io" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

    </div>

    <!-- ================= CATEGORY 3: DSAR / CMP ================= -->
    <h2 id="dsar-cmp">3. DSAR &amp; consent management platforms</h2>
    <p>Data Subject Access Request (DSAR) and enterprise consent management platforms automate the process of receiving, verifying, and responding to privacy rights requests (access, deletion, portability) mandated by GDPR, CCPA, and similar laws. Enterprise-grade CMPs extend further into data inventory, vendor assessments, and AI governance. This category skews enterprise &mdash; most tools require a sales conversation before pricing is disclosed.</p>

    <div class="card-grid">

      <article class="card">
        <h3 class="card__title">OneTrust</h3>
        <p class="card__desc">Broadest enterprise privacy, GRC, and consent platform on the market &mdash; DSAR, data mapping, vendor risk, AI governance. <em>Min $10K/yr as of Q2 2026.</em></p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://www.vendr.com/marketplace/onetrust" rel="noopener">~$10K&#47;yr min</a></span></div>
        <div class="card__cta"><a href="https://www.onetrust.com" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">TrustArc</h3>
        <p class="card__desc">Modular enterprise privacy management; strong on DSAR automation and assessments; all pricing sales-led.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://checkthat.ai/brands/trustarc/pricing" rel="noopener">~$8&ndash;15K&#47;yr</a></span></div>
        <div class="card__cta"><a href="https://trustarc.com" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">Securiti.ai <em style="font-weight:400; font-size:0.85em;">(also Cat 4)</em></h3>
        <p class="card__desc">AI-powered data command center covering DSAR, consent, data discovery, breach response, and AI governance across hybrid cloud.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://securiti.ai/pricing/" rel="noopener">Custom quote</a></span></div>
        <div class="card__cta"><a href="https://securiti.ai" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">DataGrail</h3>
        <p class="card__desc">Agentic data privacy platform with 2,500+ integrations for DSR automation and data mapping; AI agent ("Vera") for ongoing privacy tasks.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://www.datagrail.io/" rel="noopener">Custom quote</a></span></div>
        <div class="card__cta"><a href="https://www.datagrail.io" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">Transcend <em style="font-weight:400; font-size:0.85em;">(also Cat 4)</em></h3>
        <p class="card__desc">Developer-first privacy platform for DSR automation, consent, and data discovery; API-native, built for engineering-led privacy programs.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://transcend.io/pricing" rel="noopener">Custom quote</a></span></div>
        <div class="card__cta"><a href="https://transcend.io" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">Ethyca</h3>
        <p class="card__desc">Open-source-rooted data governance and consent platform (Fides); embeds privacy policy enforcement into application infrastructure.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://ethyca.com/pricing" rel="noopener">Custom quote</a></span></div>
        <div class="card__cta"><a href="https://ethyca.com" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

    </div>

    <!-- ================= CATEGORY 4: DATA DISCOVERY ================= -->
    <h2 id="data-discovery">4. Data discovery &amp; mapping</h2>
    <p>Data discovery and mapping tools scan structured and unstructured data across cloud, on-premise, and SaaS environments to find where personal and sensitive data lives, classify it, and maintain a live data inventory. This is foundational to GDPR Article 30 records-of-processing compliance and to minimising breach exposure. All tools here are enterprise-priced with custom quotes.</p>

    <div class="card-grid">

      <article class="card">
        <h3 class="card__title">BigID</h3>
        <p class="card__desc">Enterprise data intelligence for discovery, classification, privacy, and AI governance across hybrid and multi-cloud. <em>Typically $100K+/yr.</em></p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://www.inspect-data.com/dspm-pricing-comparison-2026/" rel="noopener">~$100K&ndash;500K&#47;yr</a></span></div>
        <div class="card__cta"><a href="https://bigid.com" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">Securiti.ai <em style="font-weight:400; font-size:0.85em;">(also Cat 3)</em></h3>
        <p class="card__desc">Unifies discovery with downstream privacy automation (consent, DSAR, breach response) &mdash; reduces multi-tool stitching.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://securiti.ai/pricing/" rel="noopener">Custom quote</a></span></div>
        <div class="card__cta"><a href="https://securiti.ai" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">Spirion</h3>
        <p class="card__desc">Sensitive data platform focused on accurate PII discovery at endpoint and repository level; agent-based deployment.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://www.selecthub.com/p/data-loss-prevention-software/spirion/" rel="noopener">~$30K&#47;yr</a></span></div>
        <div class="card__cta"><a href="https://www.spirion.com" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">Transcend <em style="font-weight:400; font-size:0.85em;">(also Cat 3)</em></h3>
        <p class="card__desc">API-native discovery and classification layered onto Transcend's broader privacy platform; engineering-first.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://transcend.io/pricing" rel="noopener">Custom quote</a></span></div>
        <div class="card__cta"><a href="https://transcend.io" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

    </div>

    <!-- ================= CATEGORY 5: BREACH MONITORING ================= -->
    <h2 id="breach-monitoring">5. Breach monitoring &amp; data leak detection</h2>
    <p>Breach monitoring tools alert organisations (or individuals) when their email addresses, credentials, or company data appear in known breach datasets, dark web markets, or data leak repositories. The category spans free consumer tools through enterprise identity threat protection platforms with active dark web recapture.</p>

    <div class="card-grid">

      <article class="card">
        <h3 class="card__title">Have I Been Pwned</h3>
        <p class="card__desc">The original breach notification service; free personal email search; paid API and domain monitoring for businesses.</p>
        <div class="card__meta"><span><strong>From:</strong> Free / <a href="https://haveibeenpwned.com/Subscription" rel="noopener">$4.39&#47;mo</a></span></div>
        <div class="card__cta"><a href="https://haveibeenpwned.com" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">SpyCloud</h3>
        <p class="card__desc">Enterprise identity threat protection using recaptured dark web data; account takeover, ransomware, and session hijacking defence.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://spycloud.com/pricing/" rel="noopener">Custom quote</a></span></div>
        <div class="card__cta"><a href="https://spycloud.com" rel="noopener nofollow" target="_blank" class="card__link">Visit site &#8594;</a></div>
      </article>

      <article class="card">
        <h3 class="card__title">UpGuard</h3>
        <p class="card__desc">Cyber risk and vendor risk management; combines external attack surface monitoring with third-party risk assessments.</p>
        <div class="card__meta"><span><strong>From:</strong> <a href="https://www.upguard.com/pricing" rel="noopener">$1,750&#47;mo</a></span></div>
